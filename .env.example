# Monorepo Global Environment Variables

# Security & Encryption
GHOST_CRYPTO_KEY="<your-ghost-crypto-key-here>"

# Firebase Admin (Service Account Configuration)
FIREBASE_ADMIN_CREDENTIALS="{ \"type\": \"service_account\", \"project_id\": \"...\" }"
FIREBASE_PROJECT_ID="<your-firebase-project-id>"

# Next.js Specific
NEXT_PUBLIC_APP_URL="https://your-production-url.com"

# External APIs
GEMINI_API_KEY="<your-gemini-api-key>"
# Add any other required environment variables across the monorepo here

# Firebase Client SDK (Standardized)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sglegalaiengine
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
