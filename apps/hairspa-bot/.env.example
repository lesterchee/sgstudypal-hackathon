# CommitPay AI — Environment Variables
# Copy this file to .env.local and fill in the values.

# Alibaba Cloud DashScope (Qwen LLM)
DASHSCOPE_API_KEY=

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase Client SDK (public, safe for browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Payment Webhook Shared Secret (used by CommitPayApp to authenticate POST /api/webhooks/payment)
CRM_WEBHOOK_SECRET=
